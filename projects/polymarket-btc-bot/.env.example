# Polymarket BTC Window Market Making Bot Configuration
# Copy this to .env and fill in your values

# ==================== WALLET & API ====================
# Ethereum private key (KEEP SECURE! - never commit to git)
WALLET_PRIVATE_KEY=your_private_key_here

# Polymarket SDK / Polygon RPC endpoint
POLYGON_RPC_URL=https://polygon-rpc.com
POLYSCAN_API_KEY=your_polygonscan_api_key

# Binance API (for reading price data, no trading needed)
BINANCE_API_KEY=        # Optional for kline data
BINANCE_API_SECRET=     

# ==================== TRADING PARAMETERS ====================
# Network selection
NETWORK_ID=137         # 1 = Mainnet, 137 = Polygon

# Trading pair constants
TRADING_PAIR=BTCUSDT
TRADE_AMOUNT_USD=5.00  # Maximum single order size

# Time window configuration
WINDOW_DURATION_SECONDS=300  # 5 minutes per window
PREDICTION_TRIGGER_T_BEFORE=10  # Trigger at T-10 seconds

# Price range for maker orders (probability-based pricing)
MIN_ORDER_PRICE=0.90
MAX_ORDER_PRICE=0.95

# Fee rate basis points (Polymarket requires this field)
DEFAULT_FEE_RATE_BPS=0     # Maker fee is typically 0

# ==================== RISK MANAGEMENT ====================
# Daily loss limit (20% of initial capital)
DAILY_LOSS_LIMIT_PCT=20.0

# Per-trade maximum loss
PER_TRADE_MAX_LOSS_USD=5.0

# Position sizing (% of total capital per trade)
POSITION_SIZE_PCT=5.0

# Auto-restart delay after pause (minutes)
PAUSE_RESTART_DELAY_MINUTES=60

# ==================== STRATEGY CONFIGURATION ====================
# Strategy parameters for momentum prediction
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

MA_FAST_PERIOD=20
MA_SLOW_PERIOD=50

BB_period=20
BB_std_dev=2.0

# Minimum confidence threshold for execution
MIN_CONFIDENCE_THRESHOLD=0.85

# Maximum consecutive losses before extended pause
MAX_CONSECUTIVE_LOSSES=3

# ==================== LATENCY BUDGET (ms) ====================
WS_LATENCY_TARGET_MS=50
STRATEGY_COMPUTE_LATENCY_MS=30
NET_LATENCY_TARGET_MS=5   # To NY VPS

# ==================== MONITORING ====================
LOG_LEVEL=INFO
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL_SEC=30
